# Variables de entorno del dashboard SMT-ONIC
# Copiar a .env y completar con valores reales (NO comitear .env)

# PostgreSQL + PostGIS (Docker, puerto 5450)
DB_HOST=localhost
DB_PORT=5450
DB_NAME=smt_onic
DB_USER=smt_admin
DB_PASSWORD=CAMBIAR_AQUI

# Rutas locales a datos externos (no incluidos en el repo — ver README)
DISCAPACIDAD_DIR=/ruta/local/a/discapacidad
VICTIMAS_DIR=/ruta/local/a/victimas
SPATIALITE_PATH=/ruta/local/a/my_smt_cmp_gdb_ambito_onic.sqlite

# Backend FastAPI
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080

# Frontend (Vite)
VITE_API_URL=http://localhost:8080
