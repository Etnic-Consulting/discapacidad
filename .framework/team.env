# ============================================================
# SMT-ONIC — Framework v2.1 (config local)
# ============================================================
# Cargar al inicio de cada sesion:
#   source ./.framework/team.env   (Git Bash)
#   . ./.framework/team.env        (PowerShell con dot-source manual)
# ============================================================

# --- Identidad del proyecto ---
export TEAM_PROJECT="smt-onic"
export TEAM_PROJECT_NAME="smt-onic"
export TEAM_PROJECT_ROOT="D:/1.Programacion/1.onic-smt-dashboard"

# --- Roles del equipo ---
export TEAM_AGENTS="clip,ollama"
export TEAM_DIRECTOR="wilson"

# --- Pizarra (canal unico, append-only JSONL) ---
export TEAM_LOG_DIR="D:/1.Programacion/1.onic-smt-dashboard/.framework/comms"
export TEAM_TIMEZONE_OFFSET="-5"

# --- Estado y backlog del proyecto ---
export TEAM_STATE="D:/1.Programacion/1.onic-smt-dashboard/.framework/STATE.md"
export TEAM_TASKS="D:/1.Programacion/1.onic-smt-dashboard/.framework/tasks/queue.jsonl"
export TEAM_POSTMORTEMS="D:/1.Programacion/1.onic-smt-dashboard/.framework/postmortems"
export TEAM_RESEARCH="D:/1.Programacion/1.onic-smt-dashboard/.framework/research"

# --- Codigo del framework (compartido entre proyectos, read-only) ---
export TEAM_FRAMEWORK_RUNTIME="D:/1.Programacion/framework_runtime_v1.1/framework_runtime"
export TEAM_FRAMEWORK_SCRIPTS="D:/1.Programacion/framework_runtime_v1.1/framework_runtime/scripts"
export TEAM_SHARED_DIR="D:/1.Programacion/.team-shared"

# --- Builder Ollama ---
export OLLAMA_URL="http://localhost:11434"
export OLLAMA_HOST="127.0.0.1"
export OLLAMA_PORT="11434"
export OLLAMA_BUILDER_MODEL="qwen2.5-coder:32b-instruct-q5_K_M"
export TEAM_BUILDER_MODEL="qwen2.5-coder:32b-instruct-q5_K_M"
export TEAM_AGENT_NAME="clip"
export TEAM_PARTNER_NAME="ollama"
export TEAM_OLLAMA_NAME="ollama"

# --- Semaforo global Ollama (compartido con otros proyectos) ---
# Si otro proyecto ya tiene N slots en uso, este proyecto espera.
# Ajustable con: python D:/1.Programacion/framework_runtime_v1.1/shared/ollama_gateway.py set-cap N
export OLLAMA_GLOBAL_CONCURRENCY="2"
export OLLAMA_ACQUIRE_TIMEOUT="300"

# --- Routing por tipo de tarea ---
# Nota: delegate_to_ollama.py ahora consulta models_ranking.json primero;
# este JSON es fallback si no hay benchmark.
export OLLAMA_ROUTING='{
  "simple_edit":   "qwen3-coder:30b-a3b-q4_K_M",
  "standard_code": "qwen2.5-coder:32b-instruct-q5_K_M",
  "complex_code":  "qwen3-coder-next:q4_K_M",
  "reasoning":     "deepseek-r1:32b",
  "vision":        "qwen2.5vl:7b",
  "agentic":       "devstral:latest"
}'

# --- Puertos del proyecto ---
# Framework API=8096, Dashboard=8097; backend FastAPI=8080; frontend Vite=5173; PostGIS=5432
export PROJECT_PORTS="5173,8080,8096,8097,5432,11434"
export PROJECT_PORT_ALLOW="docker.exe,com.docker.backend.exe,vpnkit.exe,ollama.exe"

# --- Crown jewels (globs separados por coma) ---
export CROWN_JEWEL_GLOBS="*/backend/app/main.py,*/backend/app/database.py,*/backend/app/services/auth.py,*/backend/app/routers/dashboard.py,*/backend/app/routers/formulario.py,*/backend/scripts/load_*.py,*/docker-compose.yml,*/frontend/package.json,*/frontend/src/context/FilterContext.jsx"

# --- Memoria persistente ---
export TEAM_MEMORY_DIR="D:/1.Programacion/1.onic-smt-dashboard/.framework/memory"

# --- NotebookLM (memoria persistente Google para ahorro de tokens) ---
export NOTEBOOKLM_NOTEBOOK_ID="58ebff66-ee37-4098-93f6-23c86a6a14f5"
export NOTEBOOKLM_NOTEBOOK_URL="https://notebooklm.google.com/notebook/58ebff66-ee37-4098-93f6-23c86a6a14f5"
